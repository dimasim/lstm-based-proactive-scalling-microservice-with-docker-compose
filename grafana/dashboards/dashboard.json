      "id": 1,
      "title": "CPU Usage (cAdvisor)",
      "type": "timeseries",
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "Prometheus"
          },
          "editorMode": "code",
          "expr": "sum(rate(container_cpu_usage_seconds_total{container_label_com_docker_compose_service=~\"(auth-service|quiz-service)\"}[30s])) by (container_label_com_docker_compose_service) * 100",
          "legendFormat": "{{container_label_com_docker_compose_service}}",
          "range": true,
          "refId": "A"
        }
      ]
    },
    {
      "collapsed": false,
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 0
      },
      "id": 2,
      "title": "Memory Usage (cAdvisor)",
      "type": "timeseries",
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "Prometheus"
          },
          "editorMode": "code",
          "expr": "sum(container_memory_working_set_bytes{container_label_com_docker_compose_service=~\"(auth-service|quiz-service)\"}) by (container_label_com_docker_compose_service) / 1024 / 1024",
          "legendFormat": "{{container_label_com_docker_compose_service}} (MB)",
          "range": true,
          "refId": "A"
        }
      ]
    },
    {
      "collapsed": false,
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 8
      },
      "id": 3,
      "title": "RPS (HAProxy)",
      "type": "timeseries",
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "Prometheus"
          },
          "editorMode": "code",
          "expr": "sum(rate(haproxy_backend_requests_total{backend=~\"(auth_back|quiz_back)\"}[30s])) by (backend)",
          "legendFormat": "{{backend}} RPS",
          "range": true,
          "refId": "A"
        }
      ]
    },
    {
      "collapsed": false,
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 8
      },
      "id": 4,
      "title": "Active Containers (cAdvisor)",
      "type": "timeseries",
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "Prometheus"
          },
          "editorMode": "code",
          "expr": "count(container_last_seen{container_label_com_docker_compose_service=~\"(auth-service|quiz-service)\"}) by (container_label_com_docker_compose_service)",
          "legendFormat": "{{container_label_com_docker_compose_service}} replicas",
          "range": true,
          "refId": "A"
        }
      ]
    }
